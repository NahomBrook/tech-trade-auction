generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  fullName         String
  email            String            @unique
  username         String            @unique
  phone            String?
  passwordHash     String
  profileImageUrl  String?
  isVerified       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  adminActions     AdminAction[]     @relation("AdminActions")
  bookings         Booking[]
  chatParticipants ChatParticipant[]
  favorites        Favorite[]
  messagesSent     Message[]         @relation("MessagesSent")
  notifications    Notification[]
  properties       Property[]
  reviews          Review[]
  roles            UserRole[]

  @@map("users")
}

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  users     UserRole[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// backend/prisma/schema.prisma
model Property {
  id             String                 @id @default(uuid())
  ownerId        String
  title          String
  description    String
  location       String
  latitude       Float
  longitude      Float
  monthlyPrice   Float
  bedrooms       Int?                   // Add this
  bathrooms      Float?                 // Add this  
  area           Float?                 // Add this
  maxGuests      Int?                   // Add this
  isAvailable    Boolean                @default(true)
  approvalStatus PropertyApprovalStatus @default(pending)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  bookings       Booking[]
  favorites      Favorite[]
  owner          User                   @relation(fields: [ownerId], references: [id])
  amenities      PropertyAmenity[]
  media          PropertyMedia[]
  reviews        Review[]

  @@map("properties")
}

model Amenity {
  id         String            @id @default(uuid())
  name       String            @unique
  properties PropertyAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model PropertyMedia {
  id         String        @id @default(uuid())
  propertyId String
  mediaUrl   String
  mediaType  MediaTypeEnum
  createdAt  DateTime      @default(now())
  property   Property      @relation(fields: [propertyId], references: [id])

  @@map("property_media")
}

model Favorite {
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, propertyId])
  @@map("favorites")
}

model Booking {
  id         String        @id @default(uuid())
  renterId   String
  propertyId String
  startDate  DateTime
  endDate    DateTime
  totalPrice Float?
  status     BookingStatus @default(pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
  property   Property      @relation(fields: [propertyId], references: [id])
  renter     User          @relation(fields: [renterId], references: [id])
  payments   Payment[]

  @@map("bookings")
}

model Review {
  id         String   @id @default(uuid())
  reviewerId String
  propertyId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  reviewer   User     @relation(fields: [reviewerId], references: [id])

  @@unique([reviewerId, propertyId])
  @@map("reviews")
}

model Chat {
  id           String            @id @default(uuid())
  createdAt    DateTime          @default(now())
  participants ChatParticipant[]
  messages     Message[]

  @@map("chats")
}

model ChatParticipant {
  chatId String
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([chatId, userId])
  @@map("chat_participants")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  message   String
  readAt    DateTime?
  isAi      Boolean  @default(false)
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id])
  sender    User     @relation("MessagesSent", fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AdminAction {
  id           String   @id @default(uuid())
  adminId      String?
  actionType   String
  targetEntity String
  targetId     String?
  notes        String?
  createdAt    DateTime @default(now())
  admin        User?    @relation("AdminActions", fields: [adminId], references: [id])

  @@map("admin_actions")
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  txRef           String        @unique 
  amount          Float
  status          PaymentStatus @default(pending)
  checkoutUrl     String?
  chapaResponse   Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

enum BookingStatus {
  pending
  approved
  rejected
  cancelled
  completed
  pending_payment
  confirmed
  failed
}

enum PaymentStatus {
  pending
  success
  failed
  cancelled
}

enum PropertyApprovalStatus {
  pending
  approved
  rejected
}

enum MediaTypeEnum {
  image
  video
}
